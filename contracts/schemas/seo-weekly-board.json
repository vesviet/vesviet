{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "contracts/schemas/seo-weekly-board.json",
  "title": "SEO Weekly Board",
  "description": "7-day dual-site topic board for machine handoff between Task Planner, SEO Analyst, and Content Writer. Produced by the optimize-seo skill under the seo-publishing overlay. Mirrors the markdown plan/baiviet/plan-YYYY-MM-DD.md board in structured JSON. Validates against overlays/seo-publishing/rules/topic-board-template.md and site-mix-and-cannibalization.md.",
  "type": "object",
  "required": [
    "board_id",
    "created_at",
    "week_start",
    "week_end",
    "timezone",
    "sites",
    "entries",
    "guardrails_check",
    "handoff"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "board_id": {
      "type": "string",
      "description": "Unique board identifier. Convention: seo-weekly-board-YYYY-MM-DD (week start date).",
      "examples": ["seo-weekly-board-2026-06-09"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "week_start": {
      "type": "string",
      "format": "date",
      "description": "First day of the 7-day board (YYYY-MM-DD)."
    },
    "week_end": {
      "type": "string",
      "format": "date",
      "description": "Last day of the 7-day board (YYYY-MM-DD)."
    },
    "timezone": {
      "type": "string",
      "const": "Asia/Ho_Chi_Minh",
      "description": "All dates and windows on this board are in UTC+7 (Asia/Ho_Chi_Minh)."
    },
    "sprint_mode": {
      "type": "string",
      "enum": ["dual_site_active", "single_site", "rest"],
      "description": "Sprint mode for the week.",
      "default": "dual_site_active"
    },
    "sites": {
      "type": "array",
      "items": { "type": "string", "enum": ["leaseinvietnam", "maylanhtreotuong"] },
      "description": "Sites active on this board. Dual-site sprint: both sites."
    },
    "entries": {
      "type": "array",
      "description": "One entry per planned post. Dual-site day = 2 entries with the same date.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "entry_id",
          "date",
          "site",
          "topic",
          "primary_keyword",
          "content_cluster",
          "search_intent",
          "target_path",
          "topical_authority",
          "geo_aeo",
          "eeat",
          "schema",
          "status"
        ],
        "properties": {
          "entry_id": {
            "type": "string",
            "description": "Unique entry identifier. Convention: YYYY-MM-DD-site-topic-slug.",
            "examples": ["2026-06-12-lease-thu-thiem"]
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "Planned publish date."
          },
          "site": {
            "type": "string",
            "enum": ["leaseinvietnam", "maylanhtreotuong"]
          },
          "topic": {
            "type": "string",
            "description": "Human-readable topic / working headline."
          },
          "primary_keyword": {
            "type": "string",
            "description": "Primary keyword for this post. Must be unique per site within the 7-day window."
          },
          "secondary_keywords": {
            "type": "array",
            "items": { "type": "string" },
            "maxItems": 4,
            "description": "2–4 secondary keywords."
          },
          "content_cluster": {
            "type": "string",
            "description": "Content cluster label per site-mix-and-cannibalization.md.",
            "examples": [
              "guides", "neighborhood-comparison", "trust-safety", "market-radar",
              "buying-guide", "technical-explainer", "comparison-review"
            ]
          },
          "search_intent": {
            "type": "string",
            "enum": ["informational", "commercial", "navigational", "transactional"]
          },
          "target_path": {
            "type": "string",
            "description": "Planned repo-relative content path or slug."
          },
          "meta_description_draft": {
            "type": "string",
            "maxLength": 160,
            "description": "Draft meta description (≤160 chars). Finalized in seo-metadata.json after audit."
          },
          "target_length_words": {
            "type": "integer",
            "minimum": 0,
            "description": "Target word count. Default minimum 1400."
          },
          "internal_links_plan": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Planned internal link targets (paths or anchors). Minimum 3.",
            "minItems": 3
          },
          "high_value_link": {
            "type": "string",
            "description": "Specific high-value property/* or product/* page to link to (weekly quota)."
          },
          "topical_authority": {
            "type": "object",
            "required": ["pillar_page_url", "cluster_position", "information_gain"],
            "properties": {
              "pillar_page_url": { "type": "string", "description": "URL or path of the pillar page this article supports." },
              "cluster_position": { "type": "string", "enum": ["pillar", "supporting", "supplementary"] },
              "information_gain": { "type": "string", "description": "What unique value this article adds beyond existing SERP results." },
              "content_freshness_type": {
                "type": "string",
                "enum": ["new_topic", "evergreen_refresh", "data_update", "experience_addition"]
              }
            },
            "additionalProperties": false
          },
          "geo_aeo": {
            "type": "object",
            "description": "GEO/AEO readiness fields. geo_ready=true when all required fields are specified.",
            "required": ["geo_ready"],
            "properties": {
              "geo_ready": {
                "type": "boolean",
                "description": "True when answer-first + query fan-out + answer format + schema types are all specified in brief."
              },
              "answer_first_block_draft": {
                "type": "string",
                "maxLength": 300,
                "description": "Draft answer-first block (≤60 words) for planning review."
              },
              "query_fan_out": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 3,
                "maxItems": 5,
                "description": "3–5 sub-questions from PAA + LLM."
              },
              "fact_density_target": {
                "type": "string",
                "description": "Minimum verifiable data points per 500 words.",
                "examples": ["3 per 500 words"]
              }
            },
            "additionalProperties": false
          },
          "eeat": {
            "type": "object",
            "description": "E-E-A-T requirements for this post.",
            "required": ["experience_proof_required"],
            "properties": {
              "experience_proof_required": {
                "type": "string",
                "enum": ["original_photo", "firsthand_account", "documented_test", "expert_interview", "case_study", "multiple", "none"]
              },
              "ymyl_adjacent": { "type": "boolean" },
              "author_entity_required": { "type": "boolean" }
            },
            "additionalProperties": false
          },
          "schema": {
            "type": "object",
            "description": "Schema types planned for this post.",
            "required": ["types"],
            "properties": {
              "types": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["Article", "FAQPage", "HowTo", "Product", "BreadcrumbList", "Person", "Organization"]
                },
                "minItems": 1
              }
            },
            "additionalProperties": false
          },
          "status": {
            "type": "string",
            "enum": ["planned", "briefed", "drafted", "audited", "published", "carry_over"],
            "description": "Lifecycle status of this board entry. briefed = seo-content-brief.json produced and geo_ready=true."
          },
          "brief_ref": {
            "type": "string",
            "description": "brief_id from seo-content-brief.json once brief is produced."
          },
          "audit_ref": {
            "type": "string",
            "description": "audit_id from seo-audit-report.json once audit is completed."
          },
          "published_url": {
            "type": "string",
            "description": "Live URL after publish. Set when status = published."
          },
          "carry_over_reason": {
            "type": "string",
            "description": "Reason for carry_over status. Included in next board."
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "guardrails_check": {
      "type": "object",
      "description": "Weekly guardrail verification by SEO Analyst before board is finalized.",
      "required": ["primary_keyword_uniqueness", "cluster_balance", "high_value_link_quota", "pillar_cluster_balance"],
      "properties": {
        "primary_keyword_uniqueness": {
          "type": "object",
          "description": "Verification that no primary keyword intent is reused per site within the 7-day window.",
          "required": ["leaseinvietnam_status", "maylanhtreotuong_status"],
          "properties": {
            "leaseinvietnam_status": { "type": "string", "enum": ["pass", "conflict_found"] },
            "leaseinvietnam_conflicts": { "type": "array", "items": { "type": "string" } },
            "maylanhtreotuong_status": { "type": "string", "enum": ["pass", "conflict_found"] },
            "maylanhtreotuong_conflicts": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "cluster_balance": {
          "type": "object",
          "description": "Content cluster distribution check — avoid 3+ consecutive posts in same cluster.",
          "required": ["leaseinvietnam_balance", "maylanhtreotuong_balance"],
          "properties": {
            "leaseinvietnam_balance": {
              "type": "object",
              "description": "Cluster distribution for Lease this week.",
              "additionalProperties": { "type": "integer" }
            },
            "leaseinvietnam_status": { "type": "string", "enum": ["balanced", "imbalanced"] },
            "maylanhtreotuong_balance": {
              "type": "object",
              "additionalProperties": { "type": "integer" }
            },
            "maylanhtreotuong_status": { "type": "string", "enum": ["balanced", "imbalanced"] }
          },
          "additionalProperties": false
        },
        "high_value_link_quota": {
          "type": "object",
          "description": "At least 1 post per week per site must link to a high-value property/* or product/* page.",
          "required": ["leaseinvietnam_met", "maylanhtreotuong_met"],
          "properties": {
            "leaseinvietnam_met": { "type": "boolean" },
            "maylanhtreotuong_met": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "pillar_cluster_balance": {
          "type": "object",
          "description": "Verify each pillar page has ≥3 supporting articles across the site (not just this week).",
          "properties": {
            "leaseinvietnam_pillar_gaps": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Pillar pages with fewer than 3 supporting articles."
            },
            "maylanhtreotuong_pillar_gaps": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "geo_readiness": {
          "type": "object",
          "description": "Count of entries with geo_ready=true vs total planned.",
          "properties": {
            "total_entries": { "type": "integer" },
            "geo_ready_count": { "type": "integer" },
            "not_ready_entry_ids": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "ai_visibility_check": {
      "type": "object",
      "description": "Weekly AI search visibility report. Manual check by SEO Analyst. Filled in weekly rollup.",
      "properties": {
        "checked_at": { "type": "string", "format": "date-time" },
        "leaseinvietnam": {
          "type": "array",
          "description": "AI citation presence per keyword for leaseinvietnam.",
          "items": {
            "type": "object",
            "required": ["keyword"],
            "properties": {
              "keyword": { "type": "string" },
              "google_ai_overview": { "type": "string", "enum": ["cited", "not_cited", "not_checked"] },
              "perplexity": { "type": "string", "enum": ["cited", "not_cited", "not_checked"] },
              "chatgpt": { "type": "string", "enum": ["cited", "not_cited", "not_checked"] },
              "citation_gap_competitors": { "type": "array", "items": { "type": "string" } },
              "action_next_week": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "maylanhtreotuong": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["keyword"],
            "properties": {
              "keyword": { "type": "string" },
              "google_ai_overview": { "type": "string", "enum": ["cited", "not_cited", "not_checked"] },
              "perplexity": { "type": "string", "enum": ["cited", "not_cited", "not_checked"] },
              "chatgpt": { "type": "string", "enum": ["cited", "not_cited", "not_checked"] },
              "citation_gap_competitors": { "type": "array", "items": { "type": "string" } },
              "action_next_week": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "handoff": {
      "type": "object",
      "description": "Board handoff routing.",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["draft", "ready_for_content_writer", "in_progress", "completed"],
          "description": "Board lifecycle status. ready_for_content_writer = all entries geo_ready=true and guardrails passed."
        },
        "next_actions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Ordered list of next steps for the week."
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "board_id": "seo-weekly-board-2026-06-09",
      "created_at": "2026-06-09T08:00:00+07:00",
      "week_start": "2026-06-09",
      "week_end": "2026-06-15",
      "timezone": "Asia/Ho_Chi_Minh",
      "sprint_mode": "dual_site_active",
      "sites": ["leaseinvietnam", "maylanhtreotuong"],
      "entries": [
        {
          "entry_id": "2026-06-12-lease-thu-thiem",
          "date": "2026-06-12",
          "site": "leaseinvietnam",
          "topic": "Thu Thiem Neighborhood Guide 2026",
          "primary_keyword": "thu thiem neighborhood guide",
          "secondary_keywords": ["renting in thu thiem", "thu thiem expat living", "thu thiem vs district 2"],
          "content_cluster": "neighborhood-comparison",
          "search_intent": "informational",
          "target_path": "post/neighborhood/thu-thiem-neighborhood-guide-2026.mdx",
          "meta_description_draft": "Complete guide to renting in Thu Thiem in 2026. Rental prices, best streets, transport links, and expat tips for District 2's newest neighborhood.",
          "target_length_words": 1600,
          "internal_links_plan": ["/guides/complete-rental-guide", "/guides/hcmc-neighborhoods", "/property/thu-thiem", "/guides/rental-safety"],
          "high_value_link": "/property/thu-thiem",
          "topical_authority": {
            "pillar_page_url": "/guides/hcmc-neighborhoods",
            "cluster_position": "supporting",
            "information_gain": "2026 rental price ranges from live listings, firsthand walkability, Metro Line 1 access detail",
            "content_freshness_type": "new_topic"
          },
          "geo_aeo": {
            "geo_ready": true,
            "answer_first_block_draft": "Thu Thiem is a modern riverside district in Ho Chi Minh City offering expat-friendly apartments from $700–$2,500/month, with new infrastructure completed in 2024 and easy Metro Line 1 access.",
            "query_fan_out": [
              "Is Thu Thiem good for expats?",
              "What is the average rent in Thu Thiem?",
              "How does Thu Thiem compare to District 1?",
              "What amenities are available in Thu Thiem?",
              "Is Thu Thiem safe to live in?"
            ],
            "fact_density_target": "3 per 500 words"
          },
          "eeat": {
            "experience_proof_required": "firsthand_account",
            "ymyl_adjacent": false,
            "author_entity_required": true
          },
          "schema": {
            "types": ["Article", "FAQPage", "BreadcrumbList"]
          },
          "status": "briefed",
          "brief_ref": "2026-06-12-lease-thu-thiem-neighborhood-guide",
          "notes": "Carry-forward from June 11 — delayed from yesterday's sprint."
        },
        {
          "entry_id": "2026-06-12-maylanh-casper-vs-daikin",
          "date": "2026-06-12",
          "site": "maylanhtreotuong",
          "topic": "Casper vs Daikin: Which Wall-Mount AC is Best for Vietnam Apartments?",
          "primary_keyword": "casper vs daikin may lanh",
          "secondary_keywords": ["may lanh casper", "may lanh daikin gia re", "may lanh tiet kiem dien"],
          "content_cluster": "comparison-review",
          "search_intent": "commercial",
          "target_path": "post/so-sanh/casper-vs-daikin-may-lanh-2026.mdx",
          "meta_description_draft": "So sánh chi tiết Casper vs Daikin 2026: giá, tiết kiệm điện, hiệu suất lạnh tại Việt Nam. Tư vấn chọn máy lạnh treo tường phù hợp.",
          "target_length_words": 1500,
          "internal_links_plan": ["/huong-dan/may-lanh-treo-tuong-tong-hop", "/product/casper-gc-09is35", "/product/daikin-ftky25wavmv", "/so-sanh/so-sanh-may-lanh-tong-hop"],
          "high_value_link": "/product/casper-gc-09is35",
          "topical_authority": {
            "pillar_page_url": "/so-sanh/so-sanh-may-lanh-tong-hop",
            "cluster_position": "supporting",
            "information_gain": "Side-by-side energy bill testing in Vietnam climate (32°C average), local price data June 2026",
            "content_freshness_type": "data_update"
          },
          "geo_aeo": {
            "geo_ready": true,
            "answer_first_block_draft": "Casper is cheaper upfront (từ 8–10 triệu đồng) while Daikin offers better long-term energy savings and warranty — Daikin wins for apartments using AC 8+ hours/day.",
            "query_fan_out": [
              "Casper hay Daikin mát hơn?",
              "Casper vs Daikin tiêu thụ điện như thế nào?",
              "Máy lạnh Casper có bền không?",
              "Daikin giá bao nhiêu 2026?"
            ],
            "fact_density_target": "3 per 500 words"
          },
          "eeat": {
            "experience_proof_required": "documented_test",
            "ymyl_adjacent": false,
            "author_entity_required": false
          },
          "schema": {
            "types": ["Article", "FAQPage"]
          },
          "status": "planned",
          "notes": "Need documented energy test data. Request from editorial or use spec sheets with local pricing."
        }
      ],
      "guardrails_check": {
        "primary_keyword_uniqueness": {
          "leaseinvietnam_status": "pass",
          "leaseinvietnam_conflicts": [],
          "maylanhtreotuong_status": "pass",
          "maylanhtreotuong_conflicts": []
        },
        "cluster_balance": {
          "leaseinvietnam_balance": { "neighborhood-comparison": 2, "guides": 1, "trust-safety": 1, "market-radar": 1 },
          "leaseinvietnam_status": "balanced",
          "maylanhtreotuong_balance": { "comparison-review": 2, "buying-guide": 2, "technical-explainer": 1 },
          "maylanhtreotuong_status": "balanced"
        },
        "high_value_link_quota": {
          "leaseinvietnam_met": true,
          "maylanhtreotuong_met": true
        },
        "pillar_cluster_balance": {
          "leaseinvietnam_pillar_gaps": [],
          "maylanhtreotuong_pillar_gaps": ["/kien-thuc/kien-thuc-may-lanh"]
        },
        "geo_readiness": {
          "total_entries": 2,
          "geo_ready_count": 1,
          "not_ready_entry_ids": ["2026-06-12-maylanh-casper-vs-daikin"]
        }
      },
      "ai_visibility_check": {
        "checked_at": "2026-06-09T09:00:00+07:00",
        "leaseinvietnam": [
          {
            "keyword": "expat apartment hcmc",
            "google_ai_overview": "not_cited",
            "perplexity": "not_cited",
            "chatgpt": "not_checked",
            "citation_gap_competitors": ["expatinfrance.com", "propertyguru.com.vn"],
            "action_next_week": "Produce answer-first FAQ article targeting this keyword with higher fact density."
          }
        ],
        "maylanhtreotuong": [
          {
            "keyword": "may lanh treo tuong tot nhat",
            "google_ai_overview": "not_checked",
            "perplexity": "not_cited",
            "chatgpt": "not_checked",
            "citation_gap_competitors": [],
            "action_next_week": "Check after comparison article publishes."
          }
        ]
      },
      "handoff": {
        "status": "in_progress",
        "next_actions": [
          "SEO Analyst: produce brief for 2026-06-12-maylanh-casper-vs-daikin (geo_ready still false)",
          "Content Writer: draft 2026-06-12-lease-thu-thiem (brief ready, geo_ready=true)",
          "Task Planner: fill remaining entries for 2026-06-13 to 2026-06-15"
        ],
        "notes": "Board partially complete. Thu Thiem entry briefed and ready for Content Writer. Casper/Daikin entry needs brief and documented test data."
      }
    }
  ]
}
